---
layout: base.njk
---
<article class="post wrap">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
  </header>

  {% if heroImage %}
    <img class="post-hero" src="{{ heroImage }}" alt="{{ heroImageAlt or title }}">
  {% endif %}

  <div class="post-body">
    {{ content | safe }}
  </div>

  {% if tags %}
    <div class="post-tags">
      {% for tag in tags %}<a class="tag" href="/tags/{{ tag | slugify }}/">{{ tag }}</a>{% endfor %}
    </div>
  {% endif %}

  {% set prevPost = collections.posts | previousPost(page.url) %}
  {% set nextPost = collections.posts | nextPost(page.url) %}
  {% if prevPost or nextPost %}
    <nav class="post-nav">
      {% if prevPost %}<a class="post-nav-prev" href="{{ prevPost.url }}">Prev: {{ prevPost.data.title }}</a>{% endif %}
      {% if nextPost %}<a class="post-nav-next" href="{{ nextPost.url }}">Next: {{ nextPost.data.title }}</a>{% endif %}
    </nav>
  {% endif %}
</article>
