---
layout: base.njk
---
<article class="post wrap">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
  </header>

  {% if heroImage %}
    <img class="post-hero" src="{{ heroImage }}" alt="{{ heroImageAlt or title }}">
  {% endif %}

  <div class="post-body">
    {{ content | safe }}
  </div>

  {% if tags %}
    <div class="post-tags">
      {% for tag in tags %}<span class="tag">{{ tag }}</span>{% endfor %}
    </div>
  {% endif %}
</article>
